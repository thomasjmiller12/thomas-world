        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.2",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "postcss": "^8.5.8",
        "tailwindcss": "^4.2.2",
        "typescript": "^5"
    }
}
