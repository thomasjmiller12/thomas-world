{
  "name": "world",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.104.1",
    "@hono/node-server": "^1.13.7",
    "@town/contract": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "pg": "^8.13.1",
    "yaml": "^2.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.20.0",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
