# apps/world environment. Copy to apps/world/.env (gitignored) and fill in.
# Every integration is env-gated: the server boots and ticks even when a key
# is absent (it degrades in-fiction and logs a one-line feature summary).

# --- core (required for local dev) -----------------------------------------
NODE_ENV=development
PORT=8787
# Postgres (docker-compose maps pgvector to host port 5433).
DATABASE_URL=postgresql://town:town@localhost:5433/town

# --- budget / admin --------------------------------------------------------
DAILY_BUDGET_USD=15
# When set, POST /admin/tick/:agentId requires header x-admin-token. When
# unset, the endpoint is allowed off-production and blocked in production.
ADMIN_TOKEN=

# --- LLM / agent runtime (runtime phase) -----------------------------------
ANTHROPIC_API_KEY=

# --- Hindsight episodic memory (feature: hindsight) ------------------------
# Needs BOTH this URL and OPENAI_API_KEY (external embeddings) to be "on".
HINDSIGHT_URL=http://localhost:8888
OPENAI_API_KEY=

# --- Langfuse tracing (feature: langfuse) ----------------------------------
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# --- Resend outbound email (feature: resend) -------------------------------
RESEND_API_KEY=

# --- Obsidian vault reference layer (feature: vault) -----------------------
# Absolute path to the synced vault clone; absent => reference tools degrade.
VAULT_DIR=
