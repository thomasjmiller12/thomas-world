# apps/world environment. Copy to apps/world/.env (gitignored) and fill in.
# Every integration is env-gated: the server BOOTS AND TICKS even when a key is
# absent. Missing integrations degrade in-fiction and the boot log prints a
# one-line feature summary: `features: { hindsight: off, langfuse: off, ... }`.
# See README.md for the full env-var table and what each one turns on.

# --- core (required for local dev) -----------------------------------------
NODE_ENV=development
PORT=8787
# Bind host: `::` (default) so Railway IPv6 private networking reaches us.
# HOST=::
# Postgres (docker-compose maps pgvector to host port 5433).
DATABASE_URL=postgresql://town:town@localhost:5433/town

# --- budget / admin --------------------------------------------------------
# Global hard ceiling across ALL agents/day (USD). Per-agent soft caps live in
# roles/<agent>.yaml. When a cap trips, the agent status → "sleeping (budget)".
DAILY_BUDGET_USD=15
# When set, POST /admin/tick/:agentId requires header `x-admin-token: <value>`.
# When unset, the endpoint is allowed off-production and blocked in production.
ADMIN_TOKEN=

# --- LLM / agent runtime (REQUIRED to tick) --------------------------------
# Without this the server still boots and serves all read endpoints, but the
# scheduler does NOT start and ticks/chats are skipped (reason "no-llm").
ANTHROPIC_API_KEY=

# --- Hindsight episodic memory (feature: hindsight) ------------------------
# Needs BOTH HINDSIGHT_URL and OPENAI_API_KEY (external embeddings) to be "on".
# Absent → remember/recall/forget return an in-fiction "memory is hazy" soft
# failure (logged once at boot). Core memory (the `memory` tool) is unaffected.
HINDSIGHT_URL=http://localhost:8888
OPENAI_API_KEY=

# --- Langfuse tracing (feature: langfuse) ----------------------------------
# Needs BOTH keys. Absent → tracing is a no-op wrapper; everything else identical.
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# --- Resend outbound email (feature: resend) -------------------------------
# Absent → email_thomas queues the message to an outbox row and reports
# queued-not-sent in-fiction (logged once at boot). Outbound-only for MVP via
# onboarding@resend.dev (no domain / DNS needed).
RESEND_API_KEY=

# --- Obsidian vault reference layer (feature: vault) -----------------------
# Absolute path to the synced vault clone. Absent → reference tools degrade
# in-fiction ("the library shipment hasn't arrived"); write_agent_note falls
# back to a local vault-pending/ dir so nothing is lost.
VAULT_DIR=
# Deploy-key sync (used by the vault sync timer when VAULT_DIR is set):
# VAULT_REPO_URL=git@github.com:you/thomas-world-vault.git
# VAULT_DEPLOY_KEY_PATH=/path/to/deploy_key
